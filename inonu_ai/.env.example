# ============================================================
# İnönü AI — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# JWT Güvenlik Ayarları
# ----------------------------------------------------------
JWT_SECRET_KEY=buraya-guclu-bir-anahtar-yazin-min-32-karakter
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------------------------------------
# Admin Giriş Bilgileri
# ----------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=inonu_ai_2025

# ----------------------------------------------------------
# SGLang / LLM Ayarları
# ----------------------------------------------------------
SGLANG_BASE_URL=http://localhost:30000/v1
SGLANG_MODEL=/home/yapayzeka/models/Qwen3-8B

# ----------------------------------------------------------
# Qdrant Vektör Veritabanı
# ----------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=inonu_docs

# ----------------------------------------------------------
# Redis (Oturum & Önbellek)
# ----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ----------------------------------------------------------
# Model Yolları
# ----------------------------------------------------------
RERANKER_MODEL_PATH=/home/yapayzeka/models/bge-reranker-v2-m3
EMBEDDING_MODEL=BAAI/bge-m3

# ----------------------------------------------------------
# Uygulama Ayarları
# ----------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
