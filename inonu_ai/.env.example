# ============================================================
# İnönü AI — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# .env dosyasını ASLA git'e commit etmeyin!
# ============================================================

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=inonu_docs

# SGLang (host'ta çalışır, Docker dışında)
SGLANG_HOST=localhost
SGLANG_PORT=30000
SGLANG_MODEL=Qwen/Qwen3-72B

# vLLM (yedek)
VLLM_HOST=localhost
VLLM_PORT=8080

# Embedding & Reranker
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
WS_PORT=8001
API_WORKERS=4

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=inonu_grafana_2025

# Crawl4AI
CRAWL_BASE_URL=https://www.inonu.edu.tr
CRAWL_MAX_CONCURRENT=5
CRAWL_SCHEDULE_HOUR=2  # Gece 02:00'de günlük kazıma

# Loglama
LOG_LEVEL=INFO
